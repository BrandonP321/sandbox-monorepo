{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": ["**/*.css", "**/*.scss"],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./icons": "./src/icons/index.ts",
    "./styles": "./src/styles/index.scss"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json --noEmit",
    "storybook": "storybook dev -p 6006 -c .storybook",
    "build-storybook": "storybook build -c .storybook",
    "test": "vitest run --project=unit --project=storybook",
    "test-storybook": "vitest run --project=storybook"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/react": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@repo/config-eslint": "workspace:*",
    "@repo/config-test": "workspace:*",
    "@repo/config-ts": "workspace:*",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.8",
    "@vitest/browser": "^3.2.4",
    "eslint": "^9.39.2",
    "playwright": "^1.58.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "storybook": "^10.2.19",
    "typescript": "^5.9.3",
    "vite": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
